{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pyright": {
      "command": ["pyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
      "initialization": {
        "settings": {
          "pyright": {
            "disableOrganizeImports": false
          }
        }
      }
    }
  }
}
